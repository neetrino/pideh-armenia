# =============================================================================
# Pideh Armenia — Environment Variables
# Copy this file to .env locally, or set these in Vercel → Settings → Environment Variables
# =============================================================================

# --- Neon PostgreSQL ---
# Dashboard: https://console.neon.tech → Project → Connection string (Pooled)
# Use the "Pooled connection" string for serverless (Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- NextAuth ---
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app (or custom domain)
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# --- Cloudflare R2 (file storage) ---
# Dashboard: Cloudflare → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="pideh-armenia"
# Public URL: R2 custom domain or r2.dev public bucket URL (must end without trailing slash)
# Example: https://pub-xxxxx.r2.dev  or  https://cdn.pideh-armenia.am
R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"

# --- App ---
NODE_ENV="development"
ADMIN_EMAIL="admin@pideh-armenia.am"
ADMIN_PASSWORD="change-me-in-production"

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""